# Optional: Google Maps Embed API key (improves IP lookup map embed)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Developer authentication (production) ---
# Recommended: Firebase Auth for email/password, Google, and social login
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=

# Transactional email via Microsoft Graph (Microsoft 365)
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# MS_GRAPH_SENDER_EMAIL=noreply@nexabitit.com

# Optional: Clerk or Auth0 (alternative to Firebase)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
