# API (local NestJS — optional, for Docker/VPS only)
PORT=4000
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT=60

# Neon PostgreSQL (create at https://neon.tech)
# Use the "pooled" connection string for serverless (Vercel)
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.us-east-1.aws.neon.tech/nexabit?sslmode=require

# Web / Vercel — leave empty to use same-origin /api routes (recommended)
NEXT_PUBLIC_API_URL=

# Microsoft Clarity analytics (production only)
NEXT_PUBLIC_CLARITY_ID=xekt49jv94

# Optional: Google Maps Embed API key (improves IP lookup map embed; works without it too)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
